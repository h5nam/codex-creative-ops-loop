# Copy to .env in a private fork. Do not commit real values.

# OpenAI image generation. Required only for:
# npm run image:generate -- --execute
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_FORMAT=png

# Meta Marketing API values. This public kit only writes redacted dry-run
# payloads; keep real live execution in a private fork behind --execute.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_REDACTED
META_PAGE_ID=PAGE_REDACTED
META_PIXEL_ID=PIXEL_REDACTED
META_GRAPH_API_VERSION=v24.0
